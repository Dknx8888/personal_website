---
import StickyNote from "../ui/StickyNote.astro";
---
<section class="cards-grid">
    <StickyNote color="yellow">
        <h5>Frameworks</h5>
        <div class="skill-pills">
            <span>React.js</span>
            <span>Astro.js</span>
            <span>.NET (learning)</span>
        </div>
    </StickyNote>
    
    <StickyNote color="blue">
        <h5>Languages</h5>
        <div class="skill-pills">
            <span>Python</span>
            <span>TypeScript</span>
            <span>SQL</span>
            <span>C# (learning)</span>
            <span>HTML</span>
            <span>CSS</span>
        </div>
    </StickyNote>
    
    <StickyNote color="green">
        <h5>Infrastructure</h5>
        <div class="skill-pills">
            <span>Docker</span>
            <span>Linux</span>
            <span>Proxmox</span>
            <span>Tailscale</span>
        </div>
    </StickyNote>
    
    <StickyNote color="pink">
        <h5>Tools & AI</h5>
        <div class="skill-pills">
            <span>Git</span>
            <span>Codex</span>
        </div>
    </StickyNote>
</section>

<style>
    .cards-grid {
        display: grid;
        grid-template-columns: repeat(4, auto);
        justify-content: space-between;
        gap: 2rem;
    }

    .skill-pills {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 12px 16px;
    }

    .skill-pills > span {
        padding: 8px;
        text-align: center;
       	background: var(--note-color, #f1eadb);
       	border: solid black 1px;
        font-size: 1.2rem;
        font-weight: bold;
    }

    @media (max-width: 767px) {
        .skill-pills > span {
            font-size: 0.8rem;
        }
    }

    @media (max-width: 1450px) {
        .cards-grid {
            grid-template-columns: repeat(2, auto);
            justify-content: center;
            justify-items: center;
            align-items: center;
            gap: 2rem;
            padding-top: 20px;
        }
    }

    @media (max-width: 767px) {
        .cards-grid {
            grid-template-columns: repeat(1, auto);
            justify-content: center;
            justify-items: center;
            align-items: center;
            gap: 4rem;
            padding-top: 20px;
        }
    }
</style>