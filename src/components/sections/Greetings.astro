---
import {Image} from "astro:assets"
import StickyNote from "../ui/StickyNote.astro"
import nickVu from "../../assets/nickvu.jpg"
---

<section class="grid grid-cols-1 gap-y-8 md:grid-cols-[1fr_auto] md:gap-y-0">
    <div>
        <h1>Hello!</h1>
        <h1 class="-mt-4.25">I'm Nick.</h1>
    </div>

    <div class="flex justify-center md:justify-end">
        <StickyNote type="photo" width="268px">
            <Image src={nickVu} alt="Nick's avatar" />
        </StickyNote>
    </div>
</section>

<div class="translate-y-11.75 md:translate-y-7.75">
    <h3>I'm a Senior Computer Science student at Michigan State University.</h3>
    <h3>When I'm not building software products, I enjoy tinkering with old technologies and experimenting with my homelab.</h3>
</div>
