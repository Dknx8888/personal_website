    bg-transparent bg-no-repeat bg-position-[bottom_right] bg-size-[auto_100%]
    px-12.5 sticky top-0 z-50"
>
    <p class="font-header text-3xl font-bold
    text-logo-ink [text-shadow:0_1px_0_rgb(255_255_255/0.35)]"
