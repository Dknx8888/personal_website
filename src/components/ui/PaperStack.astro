---
import PaperPin from "./PaperPin.astro"

interface Props {
    pinColor?: "red" | "yellow" | "blue" | "pink" | "green";
}

const {
    pinColor = "red",
} = Astro.props;
---

<div class="paper-stack">
    <PaperPin color={pinColor}/>
    <slot />
</div>

<style>
.paper-stack {
    --paper-color: #f1eadb;
    --line-color: #56808261;
    --margin-line-color:#b253438c;
    --line-height: 48px;
    --margin-line-x: 56px;

    background-color: var(--paper-color);

    background-image: 
        url("../../assets/textures/rice-paper.png"),
        linear-gradient(
        /* Red line */
            to right,
            transparent 0,
            transparent calc(var(--margin-line-x) - 1px),

            var(--margin-line-color) calc(var(--margin-line-x) - 1px),
            var(--margin-line-color) var(--margin-line-x),

            transparent var(--margin-line-x)
        ),

        /* Blue line */
        repeating-linear-gradient(
            to bottom,

            transparent 0,
            transparent calc(var(--line-height) - 1px),

            var(--line-color) calc(var(--line-height) - 1px),
            var(--line-color) var(--line-height)
        );

    background-size:
        100% 100%,
        100% var(--line-height);

    background-repeat:
        no-repeat,
        repeat;

    box-shadow: 0 0 10px #0000004d;
    margin: 50px auto 0;
    width: min(920px, calc(100% - 4rem));
    min-height: 300px;
    line-height: var(--line-height);

    padding: 5px 24px 72px calc(var(--margin-line-x) + 24px);   
    position: relative;
    overflow: visible;
}

@media (max-width: 767px) {
    .paper-stack {
        --line-height: 32px;
        --margin-line-x: 0px;

        background-image:
            url("../../assets/textures/rice-paper.png"),
            repeating-linear-gradient(
                to bottom,

                transparent 0,
                transparent calc(var(--line-height) - 1px),

                var(--line-color) calc(var(--line-height) - 1px),
                var(--line-color) var(--line-height)
            );

        background-size:
            100% 100%,
            100% var(--line-height);

        background-repeat:
            no-repeat,
            repeat;

        box-sizing: border-box ;
        padding-left: 24px;
        width: calc(100% - 0.5rem);
    }
}


.paper-stack::before, .paper-stack::after {
    content: "";
    height: 98%;
    position: absolute;
    width: 100%;
    z-index: -1;
    background-color: #f1eadb;
    background-image: url("../../assets/textures/rice-paper.png");
}

.paper-stack::before {
    box-shadow: 0 0 8px rgba(0,0,0,0.2);
    left: -5px;
    top: 4px;
    transform: rotate(-2.5deg);
}

.paper-stack::after {
    box-shadow: 0 0 3px rgba(0,0,0,0.2);
    right: -3px;
    top: 1px;
    transform: rotate(1.4deg);
}
</style>